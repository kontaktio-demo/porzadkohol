# ============================================================
#  MWW Backend – Zmienne środowiskowe
# ============================================================

# Port serwera (Render ustawi automatycznie)
PORT=3000

# MongoDB connection string (np. z MongoDB Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/mww?retryWrites=true&w=majority

# JWT secret – wygeneruj długi, losowy ciąg znaków
JWT_SECRET=ZMIEN_NA_LOSOWY_CIAG_ZNAKOW_MIN_32_ZNAKI

# JWT token expiration (np. 24h, 7d)
JWT_EXPIRES_IN=24h

# Dozwolone originy (CORS) – oddzielone przecinkami
# Podaj adres frontendu i panelu admina
CORS_ORIGINS=https://twoja-strona.pl,https://admin.twoja-strona.pl,http://localhost:5500

# Domyślne dane admina (używane przez seed.js)
ADMIN_USERNAME=mww
ADMIN_PASSWORD=MWW2024!Secure

# Maksymalny rozmiar przesyłanego pliku w MB
MAX_FILE_SIZE_MB=10

# Format obrazów wyjściowych: avif, webp lub both
IMAGE_FORMAT=both

# Jakość kompresji obrazów (1-100)
IMAGE_QUALITY=80

# Maksymalna szerokość obrazu (px) – większe będą skalowane
IMAGE_MAX_WIDTH=1920

# Maksymalna szerokość miniaturki (px)
THUMB_MAX_WIDTH=400

# Node environment
NODE_ENV=production
