# ============================================================
#  MWW Backend – Zmienne środowiskowe
# ============================================================

# Port serwera (Render ustawi automatycznie)
PORT=3000

# ─── Supabase ─────────────────────────────────────────────
# Znajdziesz je w Supabase Dashboard → Settings → API
SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUz...  

# UWAGA: Użyj service_role key (NIE anon key) – backend musi mieć
# pełny dostęp do tabel bez RLS. Nie ujawniaj tego klucza publicznie.

# ─── JWT ──────────────────────────────────────────────────
# Własny JWT do autoryzacji panelu admina (NIE token Supabase)
JWT_SECRET=ZMIEN_NA_LOSOWY_CIAG_ZNAKOW_MIN_32_ZNAKI
JWT_EXPIRES_IN=24h

# ─── CORS ─────────────────────────────────────────────────
# Dozwolone originy – oddzielone przecinkami
CORS_ORIGINS=https://twoja-strona.pl,https://admin.twoja-strona.pl,http://localhost:5500

# ─── Domyślne dane admina (seed.js) ──────────────────────
ADMIN_USERNAME=mww
ADMIN_PASSWORD=ZMIEN_NA_BEZPIECZNE_HASLO

# ─── Obrazy ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
IMAGE_FORMAT=both
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1920
THUMB_MAX_WIDTH=400

# ─── Środowisko ──────────────────────────────────────────
NODE_ENV=production
